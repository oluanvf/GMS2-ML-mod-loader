	ds[$ "global"]										=	global;
	#endregion
	
	#region import scripts
	for(var i = 0; script_get_name(i)!="<unknown>"; i++)
	{
		var _name	= string_replace_all(script_get_name(i), "@", "");
		ds[$ _name]	= i;
		show_debug_message($"script '{_name}' = {i}")
	}
	#endregion
	
	#region import assets
	var _types = [asset_animationcurve, asset_font, asset_object, asset_particlesystem, asset_path, asset_room, asset_script, asset_sequence, asset_shader, asset_sound, asset_sprite, asset_tiles, asset_timeline]
	for(var i = 0; i < array_length(_types); i++)
	{
		var _ids = asset_get_ids(_types[i]);
		for(var o = 0; o < array_length(_ids); o++)
		{
			var _name	= _ids[o];
			var _asset	= asset_get_index(_name);
			_name = string_copy(_name, string_pos(" ", _name)+1, string_length(_name))
			_name = string_copy(_name, string_pos(" ", _name)+1, string_length(_name))
			ds[$ _name] = _asset;
			show_debug_message($"asset '{_name}' = {_asset}");
		}
	}
	
	
	
	#endregion
	
	
	return ds;
}